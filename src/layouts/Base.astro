---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'Fusion Energy Workforce — Learn fusion, free',
  description = 'A free, open guide to learning plasma and fusion physics and to the commercial fusion industry: courses, videos, simulators, companies, academic programs and the major fusion labs.',
  image = '/og-image.png',
  type = 'website',
  noindex = false,
  jsonLd = [],
} = Astro.props;

const site = (Astro.site ?? new URL('https://fusionenergyworkforce.com')).toString().replace(/\/$/, '');
const path = Astro.url.pathname;
const canonical = new URL(path, site + '/').toString();
const ogImage = new URL(image, site + '/').toString();

// Breadcrumbs for non-home pages
const sectionMap = {
  learn: 'Learn fusion',
  commercial: 'Commercial fusion',
  programs: 'Academic programs',
  facilities: 'Major facilities',
  about: 'About',
};
const segment = path.split('/').filter(Boolean)[0];
const isHome = !segment;

const organization = {
  '@type': 'EducationalOrganization',
  '@id': `${site}/#organization`,
  name: 'Fusion Energy Workforce',
  url: `${site}/`,
  logo: `${site}/favicon.svg`,
  description:
    'A free, open educational hub for learning plasma physics and fusion energy, and for exploring the fusion industry, academic programs and laboratories. Grew out of the NSF-funded Workforce Accelerator for Fusion Energy Development.',
};

const website = {
  '@type': 'WebSite',
  '@id': `${site}/#website`,
  name: 'Fusion Energy Workforce',
  url: `${site}/`,
  description,
  inLanguage: 'en',
  publisher: { '@id': `${site}/#organization` },
};

const breadcrumb =
  isHome || !sectionMap[segment]
    ? null
    : {
        '@type': 'BreadcrumbList',
        itemListElement: [
          { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
          { '@type': 'ListItem', position: 2, name: sectionMap[segment], item: canonical },
        ],
      };

const graph = [organization, website, ...(breadcrumb ? [breadcrumb] : []), ...(Array.isArray(jsonLd) ? jsonLd : [jsonLd])];
const structuredData = { '@context': 'https://schema.org', '@graph': graph };
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1'} />
    <meta name="author" content="Fusion Energy Workforce" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#ff8a3d" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Fusion Energy Workforce" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Fusion Energy Workforce — learn fusion, free" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap.xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Poppins:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    <Nav path={path} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
